generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password          String?
  passwordChangedAt DateTime?
  role              String    @default("STUDENT") // ADMIN, TEACHER, STUDENT
  aiPromptTemplate  String?
  dailyGoal         Int?      // daily question goal, null = not set
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  questions           Question[]
  exams               Exam[]
  notes               Note[]
  favorites           Favorite[]
  wrongRecords        WrongRecord[]
  questionBanks       QuestionBank[]
  userDifficulties    UserDifficulty[]
  inviteCodesCreated  InviteCode[] @relation("InviteCodesCreated")
  usedInviteCode      InviteCode?  @relation("InviteCodeUsed")
  hiddenBanks         HiddenBank[]
  reviewCards         ReviewCard[]
  reviewLogs          ReviewLog[]
  knowledgeEntries    KnowledgeEntry[]
  uploadedImages      UploadedImage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model QuestionBank {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy  User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  questions  Question[]
  hiddenBy   HiddenBank[]
}

model Question {
  id                     String   @id @default(cuid())
  stem                   String
  type                   String   @default("SINGLE") // SINGLE, MULTI, SCENARIO
  options                String   // JSON: [{label: "A", text: "..."}, ...]
  answer                 String   // "A" or "A,B" for multi
  explanation            String
  wrongOptionExplanations String? // JSON: {A: "...", B: "...", ...}
  extendedKnowledge      String?
  questionBankId         String   // FK to QuestionBank
  category               String?  // user-defined category/label for the question
  chapter                String?
  difficulty             Int      @default(3) // 1-5
  tags                   String   @default("[]") // JSON array
  version                Int      @default(1)
  createdById            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  questionBank  QuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  createdBy     User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  examAnswers      ExamAnswer[]
  notes            Note[]
  favorites        Favorite[]
  wrongRecords     WrongRecord[]
  userDifficulties UserDifficulty[]
  reviewCards      ReviewCard[]
  reviewLogs       ReviewLog[]
}

model UserDifficulty {
  id         String @id @default(cuid())
  userId     String
  questionId String
  difficulty Int    // 1-5

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model Exam {
  id        String   @id @default(cuid())
  userId    String
  title     String
  mode      String   // PRACTICE, MOCK
  config    String   // JSON
  status    String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, ABANDONED
  score     Float?
  startedAt DateTime @default(now())
  finishedAt DateTime?
  timeLimit Int?     // seconds

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers ExamAnswer[]
}

model ExamAnswer {
  id         String   @id @default(cuid())
  examId     String
  questionId String
  userAnswer String?
  isCorrect  Boolean?
  timeSpent  Int?     // seconds
  order      Int      @default(0)
  flagged    Boolean  @default(false)
  createdAt  DateTime @default(now())

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  reviewLogs ReviewLog[]

  @@unique([examId, questionId])
}

model Note {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model WrongRecord {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  count       Int      @default(1)
  lastWrongAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  createdById String
  maxUses     Int       @default(0)  // 0 = unlimited
  usedCount   Int       @default(0)
  usedById    String?   @unique      // kept for backward compat (first user)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  createdBy User  @relation("InviteCodesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  usedBy    User? @relation("InviteCodeUsed", fields: [usedById], references: [id], onDelete: SetNull)
}

model HiddenBank {
  id             String   @id @default(cuid())
  userId         String
  questionBankId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionBank QuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)

  @@unique([userId, questionBankId])
}

// ── Spaced Repetition System (SRS) ──

model ReviewCard {
  id             String    @id @default(cuid())
  userId         String
  questionId     String
  status         String    @default("NEW") // NEW, LEARNING, REVIEW, MASTERED
  interval       Float     @default(1)     // days until next review
  easeFactor     Float     @default(2.5)   // SM-2 ease factor
  repetitions    Int       @default(0)     // consecutive correct answers
  lapses         Int       @default(0)     // times forgotten (correct → wrong)
  nextDueAt      DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  reviewLogs ReviewLog[]

  @@unique([userId, questionId])
  @@index([userId, nextDueAt])
  @@index([userId, status])
}

model ReviewLog {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  reviewCardId   String
  rating         Int      // 1=Again, 2=Hard, 3=Good, 4=Easy
  intervalBefore Float
  intervalAfter  Float
  examAnswerId   String?  // linked to ExamAnswer if auto-rated from exam
  reviewedAt     DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reviewCard ReviewCard  @relation(fields: [reviewCardId], references: [id], onDelete: Cascade)
  examAnswer ExamAnswer? @relation(fields: [examAnswerId], references: [id], onDelete: SetNull)

  @@index([userId, reviewedAt])
}

// ── Uploaded Images ──

model UploadedImage {
  id        String   @id @default(cuid())
  filename  String
  r2Key     String   @unique
  size      Int
  mimeType  String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Knowledge Base ──

model KnowledgeEntry {
  id        String   @id @default(cuid())
  tag       String
  content   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag])
}
